{%- comment -%}
  Renders product highlights badges/pills slider.
  Accepts:
  - block: {Object} passes block settings to the snippet.

  Usage:
  {% render 'product-highlights', block: block %}
{%- endcomment -%}

{%- assign font_size_desktop = block.settings.font_size_desktop -%}
{%- assign font_size_mobile = block.settings.font_size_mobile -%}
{%- assign border_radius = block.settings.border_radius -%}
{% style %}
  /* =====================================================
   Product Highlights Badge Slider
   ===================================================== */
  .product-highlights {
    margin: 1.5rem 0;
    width: 100%;
  }

  .highlights-list {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.2rem;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding: 0.4rem 0.2rem;
    scrollbar-width: none; /* Hide scrollbar for Firefox */
    -ms-overflow-style: none; /* Hide scrollbar for IE/Edge */
    -webkit-overflow-scrolling: touch;
  }

  .highlights-list::-webkit-scrollbar {
    display: none; /* Hide scrollbar for Chrome/Safari */
  }

  .highlight-pill {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.6rem 1.6rem;
    border-radius: var(--pill-border-radius, 3rem);
    font-size: var(--pill-font-size-mobile, 1.2rem);
    font-weight: 500;
    line-height: 1.2;
    white-space: nowrap;
    background-color: rgba(var(--color-foreground), 0.06);
    border: 1px solid rgba(var(--color-foreground), 0.12);
    color: rgb(var(--color-foreground));
    flex-shrink: 0;
    transition: transform var(--duration-short) ease, background-color var(--duration-short) ease;
  }

  .highlight-pill:hover {
    transform: translateY(-1px);
  }

  .highlight-pill__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: rgba(var(--color-foreground), 0.1);
  }

  .highlight-pill__icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .highlight-pill__icon svg,
  .highlight-pill__icon svg path {
    width: 1.2rem;
    height: 1.2rem;
    fill: currentColor;
  }

  @media screen and (min-width: 750px) {
    .highlight-pill {
      font-size: var(--pill-font-size-desktop, 1.4rem);
      gap: 1rem;
      padding: 0.8rem 1.8rem;
    }
  }
{% endstyle %}
<div
  class="product-highlights"
  {{ block.shopify_attributes }}
  style="
    --pill-font-size-desktop: {{ font_size_desktop }}px;
    --pill-font-size-mobile: {{ font_size_mobile }}px;
    --pill-border-radius: {{ border_radius }}px;
  "
>
  <div class="highlights-list">
    {%- for i in (1..6) -%}
      {%- assign text_key = 'text_' | append: i -%}
      {%- assign image_key = 'image_' | append: i -%}
      {%- assign svg_key = 'svg_' | append: i -%}

      {%- assign item_text = block.settings[text_key] -%}
      {%- assign item_image = block.settings[image_key] -%}
      {%- assign item_svg = block.settings[svg_key] -%}

      {%- if item_text != blank or item_image != blank or item_svg != blank -%}
        <div class="highlight-pill">
          {%- if item_image != blank or item_svg != blank -%}
            <div class="highlight-pill__icon">
              {%- if item_image != blank -%}
                <img src="{{ item_image | image_url: width: 40 }}" alt="" loading="lazy" width="20" height="20">
              {%- elsif item_svg != blank -%}
                {{ item_svg }}
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if item_text != blank -%}
            <span class="highlight-pill__text">{{ item_text }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>
