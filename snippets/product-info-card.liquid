{%- comment -%}
  Renders product info card block (e.g. Mission statement or Commitment details).
  Accepts:
  - block: {Object} passes block settings to the snippet.

  Usage:
  {% render 'product-info-card', block: block %}
{%- endcomment -%}

{% style %}
  #ProductInfoCard-{{ block.id }} {
    margin: 1.5rem 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    text-align: left;
    width: 100%;
  }

  #ProductInfoCard-{{ block.id }} .product-info-card__header {
    font-size: calc({{ block.settings.font_size_mobile }}px * 0.85);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    line-height: 1.2;
    color: {{ block.settings.header_color }};
  }

  #ProductInfoCard-{{ block.id }} .product-info-card__body {
    font-size: {{ block.settings.font_size_mobile }}px;
    line-height: 1.6;
    color: {{ block.settings.body_color }};
  }

  #ProductInfoCard-{{ block.id }} .product-info-card__body p {
    margin: 0;
    color: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  #ProductInfoCard-{{ block.id }} .product-info-card__footer {
    font-size: {{ block.settings.font_size_mobile }}px;
    font-weight: 700;
    line-height: 1.4;
    color: {{ block.settings.footer_color }};
  }

  @media screen and (min-width: 750px) {
    #ProductInfoCard-{{ block.id }} .product-info-card__header {
      font-size: calc({{ block.settings.font_size_desktop }}px * 0.85);
    }
    #ProductInfoCard-{{ block.id }} .product-info-card__body {
      font-size: {{ block.settings.font_size_desktop }}px;
    }
    #ProductInfoCard-{{ block.id }} .product-info-card__footer {
      font-size: {{ block.settings.font_size_desktop }}px;
    }
  }
{% endstyle %}

<div id="ProductInfoCard-{{ block.id }}" class="product-info-card" {{ block.shopify_attributes }}>
  {%- if block.settings.header_text != blank -%}
    <div class="product-info-card__header">{{ block.settings.header_text }}</div>
  {%- endif -%}
  {%- if block.settings.body_text != blank -%}
    <div class="product-info-card__body rte">{{ block.settings.body_text }}</div>
  {%- endif -%}
  {%- if block.settings.footer_text != blank -%}
    <div class="product-info-card__footer">{{ block.settings.footer_text }}</div>
  {%- endif -%}
</div>
